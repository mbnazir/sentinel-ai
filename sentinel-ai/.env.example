APP_NAME=Sentinel AI
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel_password
POSTGRES_DB=sentinel_ai
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
JWT_SECRET_KEY=change-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO


# SSO - Azure AD / Entra ID
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_DEFAULT_ORG=ORG-DEFAULT

# SSO - Google Workspace
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=
GOOGLE_DEFAULT_ORG=ORG-DEFAULT


# Quartz API connector
QUARTZ_API_BASE_URL=
QUARTZ_API_KEY=
QUARTZ_API_PAGE_SIZE=500
QUARTZ_API_MAX_RETRIES=3
